# ==============================================================================
# ESP-IDF Build Artifacts
# ==============================================================================
**/build/
**/sdkconfig
**/sdkconfig.old
**/sdkconfig.json
**/managed_components/
**/dependencies.lock

# ==============================================================================
# Compiled Binaries (keep release binaries in releases/)
# ==============================================================================
*.bin
*.elf
*.map
*.uf2

# ==============================================================================
# IDE & Editor
# ==============================================================================
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==============================================================================
# Logs & Debug
# ==============================================================================
*.log
core.*
crash_*.dmp

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# ==============================================================================
# Documentation Build
# ==============================================================================
docs/_build/
docs/.doctrees/

# ==============================================================================
# Temporary Files
# ==============================================================================
tmp/
temp/
*.tmp

# ==============================================================================
# CMake Presets Build Directories
# ==============================================================================
build/linux-debug/
build/linux-release/
build/windows-msvc-2022/
build/windows-msvc-2022-debug/
build/windows-msvc-2019/
build/windows-mingw/
build/windows-mingw-debug/
build/macos-clang/
install/
*.user
*.sln
*.vcxproj*
*.opensdf
*.VC.db
ipch/

# ==============================================================================
# Secrets & Credentials (NEVER commit these!)
# ==============================================================================
*.pem
*.key
*.crt
secrets/
.env
.env.local
