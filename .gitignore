# SPDX-License-Identifier: Apache-2.0
# HeteroLink Root .gitignore
# Note: See unit/.gitignore and dashboard/.gitignore for component-specific rules

# ==============================================================================
# Documentation Build
# ==============================================================================
docs/_build/
docs/.doctrees/

# ==============================================================================
# Secrets & Credentials (NEVER commit these!)
# ==============================================================================
*.pem
*.key
*.crt
secrets/
.env
.env.local

# ==============================================================================
# Release Binaries (use releases/ folder for distribution)
# ==============================================================================
releases/*.bin
releases/*.exe
releases/*.zip

# ==============================================================================
# OS Generated Files
# ==============================================================================
.DS_Store
Thumbs.db
desktop.ini
