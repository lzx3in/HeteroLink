<!DOCTYPE RCC>
<RCC version="1.0">
    <qresource prefix="/">
        <!-- 样式表 -->
        <file>styles/dark.qss</file>
        
        <!-- 自定义图标（系统主题没有的） -->
        <!-- 设备状态图标需要自定义，因为系统主题没有在线/离线状态 -->
        <file>icons/device_online.svg</file>
        <file>icons/device_offline.svg</file>
    </qresource>
</RCC>
