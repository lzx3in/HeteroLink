{
  "version": 10,
  "$schema": "https://raw.githubusercontent.com/Kitware/CMake/master/Help/manual/presets/schema.json",
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "displayName": "Base Config",
      "description": "基础配置",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "base-windows",
      "hidden": true,
      "displayName": "Base Windows Config",
      "description": "Windows 基础配置",
      "inherits": "base",
      "binaryDir": "${sourceDir}\\build\\${presetName}",
      "installDir": "${sourceDir}\\install\\${presetName}",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-system",
      "displayName": "Linux System Compiler",
      "description": "使用 Linux 系统编译器（GCC/Clang），避免 ESP-IDF 工具链干扰",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_C_FLAGS": "-m64",
        "CMAKE_CXX_FLAGS": "-m64"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release Build",
      "description": "Linux Release 版本",
      "inherits": "linux-system",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS_RELEASE": "-O3 -DNDEBUG",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug Build",
      "description": "Linux Debug 版本（带调试信息）",
      "inherits": "linux-system",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_FLAGS_DEBUG": "-g -O0",
        "CMAKE_CXX_FLAGS_DEBUG": "-g -O0"
      }
    },
    {
      "name": "windows-msvc-2026",
      "displayName": "Windows MSVC 2026 x64",
      "description": "Visual Studio 2026 64 位版本",
      "inherits": "base-windows",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "/W4 /permissive- /Zc:__cplusplus",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /DNDEBUG",
        "CMAKE_CXX_FLAGS_DEBUG": "/Zi /Od /RTC1"
      }
    },
    {
      "name": "windows-msvc-2026-debug",
      "displayName": "Windows MSVC 2026 x64 Debug",
      "description": "Visual Studio 2026 64 位 Debug 版本",
      "inherits": "windows-msvc-2026",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS_DEBUG": "/Zi /Od /RTC1 /MDd"
      }
    },
    {
      "name": "windows-msvc-2019",
      "displayName": "Windows MSVC 2019 x64",
      "description": "Visual Studio 2019 (v142) 64 位",
      "inherits": "base-windows",
      "generator": "Visual Studio 16 2019",
      "architecture": "x64",
      "toolset": "v142",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "/W4 /permissive-",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /DNDEBUG"
      }
    },
    {
      "name": "windows-mingw",
      "displayName": "Windows MinGW GCC",
      "description": "MinGW GCC 编译器（需要安装 MSYS2 或 MinGW-w64）",
      "inherits": "base-windows",
      "generator": "MinGW Makefiles",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_C_FLAGS": "-m64",
        "CMAKE_CXX_FLAGS": "-m64 -static-libgcc -static-libstdc++",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG",
        "CMAKE_CXX_FLAGS_DEBUG": "-g -O0"
      }
    },
    {
      "name": "windows-mingw-debug",
      "displayName": "Windows MinGW GCC Debug",
      "description": "MinGW GCC Debug 版本",
      "inherits": "windows-mingw",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS_DEBUG": "-g -O0"
      }
    },
    {
      "name": "macos-clang",
      "displayName": "macOS Clang",
      "description": "macOS Clang 编译器",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug-build",
      "displayName": "Build Debug",
      "configurePreset": "linux-debug",
      "configuration": "Debug"
    },
    {
      "name": "linux-release-build",
      "displayName": "Build Release",
      "configurePreset": "linux-release",
      "configuration": "Release"
    },
    {
      "name": "windows-msvc-2026-build",
      "displayName": "Build MSVC 2026",
      "configurePreset": "windows-msvc-2026",
      "configuration": "Release"
    },
    {
      "name": "windows-msvc-2026-debug-build",
      "displayName": "Build MSVC 2026 Debug",
      "configurePreset": "windows-msvc-2026-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-msvc-2019-build",
      "displayName": "Build MSVC 2019",
      "configurePreset": "windows-msvc-2019",
      "configuration": "Release"
    },
    {
      "name": "windows-mingw-build",
      "displayName": "Build MinGW",
      "configurePreset": "windows-mingw",
      "configuration": "Release"
    },
    {
      "name": "windows-mingw-debug-build",
      "displayName": "Build MinGW Debug",
      "configurePreset": "windows-mingw-debug",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "linux-debug-test",
      "displayName": "Test Debug",
      "configurePreset": "linux-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-msvc-2026-test",
      "displayName": "Test MSVC 2026",
      "configurePreset": "windows-msvc-2026",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-mingw-test",
      "displayName": "Test MinGW",
      "configurePreset": "windows-mingw",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "linux-debug-workflow",
      "displayName": "Linux Debug Workflow",
      "description": "完整的 Linux Debug 构建工作流（配置→构建→测试）",
      "steps": [
        {
          "type": "configure",
          "name": "linux-debug"
        },
        {
          "type": "build",
          "name": "linux-debug-build"
        },
        {
          "type": "test",
          "name": "linux-debug-test"
        }
      ]
    },
    {
      "name": "linux-release-workflow",
      "displayName": "Linux Release Workflow",
      "description": "完整的 Linux Release 构建工作流（配置→构建→测试）",
      "steps": [
        {
          "type": "configure",
          "name": "linux-release"
        },
        {
          "type": "build",
          "name": "linux-release-build"
        }
      ]
    },
    {
      "name": "windows-msvc-2026-workflow",
      "displayName": "Windows MSVC 2026 Workflow",
      "description": "完整的 Windows MSVC 2026 构建工作流（配置→构建→测试）",
      "steps": [
        {
          "type": "configure",
          "name": "windows-msvc-2026"
        },
        {
          "type": "build",
          "name": "windows-msvc-2026-build"
        },
        {
          "type": "test",
          "name": "windows-msvc-2026-test"
        }
      ]
    },
    {
      "name": "windows-mingw-workflow",
      "displayName": "Windows MinGW Workflow",
      "description": "完整的 Windows MinGW 构建工作流（配置→构建→测试）",
      "steps": [
        {
          "type": "configure",
          "name": "windows-mingw"
        },
        {
          "type": "build",
          "name": "windows-mingw-build"
        },
        {
          "type": "test",
          "name": "windows-mingw-test"
        }
      ]
    }
  ]
}
