{
  "version": 10,
  "$schema": "https://raw.githubusercontent.com/Kitware/CMake/master/Help/manual/presets/schema.json",
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "displayName": "Base Config",
      "description": "Base configuration with vcpkg integration",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "base-windows",
      "hidden": true,
      "displayName": "Base Windows Config",
      "description": "Base configuration for Windows platforms",
      "inherits": "base",
      "binaryDir": "${sourceDir}\\build\\${presetName}",
      "installDir": "${sourceDir}\\install\\${presetName}",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "lnx-gcc",
      "hidden": true,
      "displayName": "Linux GCC",
      "description": "Linux system compiler (GCC), avoids ESP-IDF toolchain conflicts",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_C_FLAGS": "-m64",
        "CMAKE_CXX_FLAGS": "-m64"
      }
    },
    {
      "name": "lnx-gcc-release",
      "displayName": "Linux GCC Release",
      "description": "Linux Release build with GCC (-O3)",
      "inherits": "lnx-gcc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS_RELEASE": "-O3 -DNDEBUG",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG"
      }
    },
    {
      "name": "lnx-gcc-debug",
      "displayName": "Linux GCC Debug",
      "description": "Linux Debug build with GCC (-g, -O0)",
      "inherits": "lnx-gcc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_FLAGS_DEBUG": "-g -O0",
        "CMAKE_CXX_FLAGS_DEBUG": "-g -O0"
      }
    },
    {
      "name": "win-msvc2026",
      "hidden": true,
      "displayName": "Windows MSVC 2026",
      "description": "Visual Studio 2026 (v144) 64-bit",
      "inherits": "base-windows",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "/W4 /permissive- /Zc:__cplusplus"
      }
    },
    {
      "name": "win-msvc2026-release",
      "displayName": "Windows MSVC 2026 Release",
      "description": "Visual Studio 2026 Release build (/O2)",
      "inherits": "win-msvc2026",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /DNDEBUG"
      }
    },
    {
      "name": "win-msvc2026-debug",
      "displayName": "Windows MSVC 2026 Debug",
      "description": "Visual Studio 2026 Debug build (/Zi, /Od, /RTC1)",
      "inherits": "win-msvc2026",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS_DEBUG": "/Zi /Od /RTC1 /MDd"
      }
    },
    {
      "name": "win-msvc2019-release",
      "displayName": "Windows MSVC 2019 Release",
      "description": "Visual Studio 2019 (v142) 64-bit Release",
      "inherits": "base-windows",
      "generator": "Visual Studio 16 2019",
      "architecture": "x64",
      "toolset": "v142",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "/W4 /permissive-",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /DNDEBUG"
      }
    },
    {
      "name": "win-gcc",
      "hidden": true,
      "displayName": "Windows MinGW GCC",
      "description": "MinGW-w64 GCC (requires MSYS2 or MinGW-w64)",
      "inherits": "base-windows",
      "generator": "MinGW Makefiles",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_C_FLAGS": "-m64",
        "CMAKE_CXX_FLAGS": "-m64 -static-libgcc -static-libstdc++"
      }
    },
    {
      "name": "win-gcc-release",
      "displayName": "Windows MinGW Release",
      "description": "MinGW GCC Release build (-O3)",
      "inherits": "win-gcc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG"
      }
    },
    {
      "name": "win-gcc-debug",
      "displayName": "Windows MinGW Debug",
      "description": "MinGW GCC Debug build (-g, -O0)",
      "inherits": "win-gcc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS_DEBUG": "-g -O0"
      }
    },
    {
      "name": "mac-clang",
      "hidden": true,
      "displayName": "macOS Clang",
      "description": "macOS system compiler (Clang)",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "mac-clang-debug",
      "displayName": "macOS Clang Debug",
      "description": "macOS Debug build with Clang",
      "inherits": "mac-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-lnx-gcc-debug",
      "displayName": "Build Linux Debug",
      "configurePreset": "lnx-gcc-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-lnx-gcc-release",
      "displayName": "Build Linux Release",
      "configurePreset": "lnx-gcc-release",
      "configuration": "Release"
    },
    {
      "name": "build-win-msvc2026-release",
      "displayName": "Build Windows MSVC 2026 Release",
      "configurePreset": "win-msvc2026-release",
      "configuration": "Release"
    },
    {
      "name": "build-win-msvc2026-debug",
      "displayName": "Build Windows MSVC 2026 Debug",
      "configurePreset": "win-msvc2026-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-win-msvc2019-release",
      "displayName": "Build Windows MSVC 2019 Release",
      "configurePreset": "win-msvc2019-release",
      "configuration": "Release"
    },
    {
      "name": "build-win-gcc-release",
      "displayName": "Build Windows MinGW Release",
      "configurePreset": "win-gcc-release",
      "configuration": "Release"
    },
    {
      "name": "build-win-gcc-debug",
      "displayName": "Build Windows MinGW Debug",
      "configurePreset": "win-gcc-debug",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "test-lnx-gcc-debug",
      "displayName": "Test Linux Debug",
      "configurePreset": "lnx-gcc-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-win-msvc2026-release",
      "displayName": "Test Windows MSVC 2026 Release",
      "configurePreset": "win-msvc2026-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-win-gcc-release",
      "displayName": "Test Windows MinGW Release",
      "configurePreset": "win-gcc-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "workflow-lnx-debug",
      "displayName": "Linux Debug Workflow",
      "description": "Complete Linux Debug build workflow (configure → build → test)",
      "steps": [
        {
          "type": "configure",
          "name": "lnx-gcc-debug"
        },
        {
          "type": "build",
          "name": "build-lnx-gcc-debug"
        },
        {
          "type": "test",
          "name": "test-lnx-gcc-debug"
        }
      ]
    },
    {
      "name": "workflow-lnx-release",
      "displayName": "Linux Release Workflow",
      "description": "Complete Linux Release build workflow (configure → build)",
      "steps": [
        {
          "type": "configure",
          "name": "lnx-gcc-release"
        },
        {
          "type": "build",
          "name": "build-lnx-gcc-release"
        }
      ]
    },
    {
      "name": "workflow-win-msvc2026",
      "displayName": "Windows MSVC 2026 Workflow",
      "description": "Complete Windows MSVC 2026 build workflow (configure → build → test)",
      "steps": [
        {
          "type": "configure",
          "name": "win-msvc2026-release"
        },
        {
          "type": "build",
          "name": "build-win-msvc2026-release"
        },
        {
          "type": "test",
          "name": "test-win-msvc2026-release"
        }
      ]
    },
    {
      "name": "workflow-win-gcc",
      "displayName": "Windows MinGW Workflow",
      "description": "Complete Windows MinGW build workflow (configure → build → test)",
      "steps": [
        {
          "type": "configure",
          "name": "win-gcc-release"
        },
        {
          "type": "build",
          "name": "build-win-gcc-release"
        },
        {
          "type": "test",
          "name": "test-win-gcc-release"
        }
      ]
    }
  ]
}
