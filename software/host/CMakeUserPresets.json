{
  "version": 10,
  "$schema": "https://raw.githubusercontent.com/Kitware/CMake/master/Help/manual/presets/schema.json",
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "custom-linux-compiler",
      "displayName": "Custom Linux Compiler Path",
      "description": "自定义 Linux 编译器路径（复制此文件并修改为你自己的路径）",
      "inherits": "linux-system",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "/usr/bin/gcc",
        "CMAKE_CXX_COMPILER": "/usr/bin/g++"
      }
    },
    {
      "name": "custom-windows-msvc",
      "displayName": "Custom Windows MSVC Path",
      "description": "自定义 Windows MSVC 路径",
      "inherits": "windows-msvc-2022",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "C:/Qt/6.8/msvc2022_64"
      }
    },
    {
      "name": "custom-windows-vcpkg",
      "displayName": "Custom Windows vcpkg",
      "description": "使用 vcpkg 管理依赖（需要修改 vcpkg 路径）",
      "inherits": "windows-msvc-2022",
      "toolchainFile": "[vcpkg-root]/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "custom-macos-qt-path",
      "displayName": "Custom macOS Qt Path",
      "description": "自定义 macOS Qt 路径（Homebrew）",
      "inherits": "macos-clang",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "/opt/homebrew/opt/qt@6"
      }
    }
  ]
}
