import { VerticalBox, HorizontalBox, Button, LineEdit, ComboBox, CheckBox, SpinBox,
         TabWidget, GroupBox, ScrollView, Palette } from "std-widgets.slint";

export struct DeviceItem {
    id: string,
    name: string,
    connected: bool,
    online: bool,
    connection-type: string,
    port: string,
}

export struct ChannelData {
    index: int,
    value: float,
}

export struct TelemetrySnapshot {
    timestamp: int,
    channel-count: int,
    ch0: float,
    ch1: float,
    ch2: float,
    ch3: float,
}

export struct StatsItem {
    channel-id: int,
    min: float,
    max: float,
    avg: float,
    rms: float,
    sample-count: int,
}

export struct AlarmItem {
    device-id: string,
    channel-id: int,
    level: string,
    value: float,
    message: string,
    timestamp: string,
    acknowledged: bool,
}

export component AppUI inherits Window {
    title: "HeteroLink Host - 异构协处理器监控平台";
    min-width: 1200px;
    min-height: 800px;
    background: #1e1e1e;
    default-font-size: 13px;

    // === 数据模型 ===
    in property <[DeviceItem]> devices;
    in property <[TelemetrySnapshot]> telemetry-data;
    in property <[StatsItem]> channel-stats;
    in property <[AlarmItem]> alarm-records;
    in property <[string]> available-ports;
    in property <[string]> log-messages;

    // === UART 配置 ===
    in-out property <int> uart-port-index: 0;
    in-out property <int> uart-baud-index: 4;  // 默认 921600
    in property <[int]> baud-rates: [9600, 19200, 38400, 57600, 115200, 230400, 460800, 921600];

    // === MQTT 配置 ===
    in-out property <string> mqtt-host: "localhost";
    in-out property <int> mqtt-port: 1883;
    in-out property <string> mqtt-username;
    in-out property <string> mqtt-password;
    in-out property <string> mqtt-client-id: "heterolink-host";
    in-out property <bool> mqtt-tls: false;

    // === 告警配置 ===
    in-out property <bool> alarm-enabled: true;
    in-out property <float> alarm-lower: -1000;
    in-out property <int> alarm-lower-int: -1000;
    in-out property <float> alarm-upper: 1000;
    in-out property <int> alarm-upper-int: 1000;

    // === 状态信息 ===
    in-out property <string> status-message: "就绪";
    in-out property <int> connected-count: 0;
    in-out property <int> online-count: 0;
    in-out property <bool> mqtt-connected: false;
    in-out property <bool> recording: false;

    // === 回调 ===
    callback connect-uart();
    callback disconnect-device(int);
    callback connect-mqtt();
    callback disconnect-mqtt();
    callback start-recording();
    callback stop-recording();
    callback export-csv();
    callback export-json();
    callback save-config();
    callback load-config();
    callback reset-config();
    callback acknowledge-alarm(int);
    callback clear-alarms();
    callback add-device(string);
    callback remove-device(int);
    callback select-device(int);

    in-out property <int> selected-device-index: -1;

    VerticalLayout {
        padding: 6px;
        spacing: 6px;

        // ============ 工具栏 ============
        Rectangle {
            height: 40px;
            background: #2d2d2d;
            border-radius: 4px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;
                alignment: start;

                Button { text: "🔌 连接"; clicked => { connect-uart(); } }
                Button { text: "断开"; clicked => { if selected-device-index >= 0 { disconnect-device(selected-device-index); } } }

                Rectangle { width: 12px; }

                Button { text: "☁ MQTT"; clicked => { connect-mqtt(); } }
                Button { text: "断开 MQTT"; clicked => { disconnect-mqtt(); } }

                Rectangle { width: 12px; }

                Button { text: recording ? "⏹ 停止记录" : "⏺ 开始记录"; clicked => { if recording { stop-recording(); } else { start-recording(); } } }

                Rectangle { width: 12px; }

                Button { text: "📊 导出 CSV"; clicked => { export-csv(); } }
                Button { text: "📄 导出 JSON"; clicked => { export-json(); } }
            }
        }

        // ============ 主内容区 ============
        HorizontalLayout {
            spacing: 6px;
            vertical-stretch: 1;

            // === 左侧: 设备面板 ===
            Rectangle {
                max-width: 280px;
                background: #252526;
                border-radius: 4px;

                VerticalLayout {
                    padding: 8px;
                    spacing: 8px;

                    Text { text: "📡 设备列表"; font-size: 15px; font-weight: 700; color: #e0e0e0; }

                    // 串口选择
                    GroupBox {
                        title: "UART 配置";

                        VerticalLayout {
                            spacing: 4px;

                            Text { text: "串口:"; color: #aaa; }
                            ComboBox {
                                model: available-ports;
                                current-index <=> uart-port-index;
                            }

                            Text { text: "波特率:"; color: #aaa; }
                            ComboBox {
                                model: ["9600", "19200", "38400", "57600", "115200", "230400", "460800", "921600"];
                                current-index <=> uart-baud-index;
                            }
                        }
                    }

                    // 设备列表
                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 4px;

                            for device[idx] in devices : Rectangle {
                                height: 56px;
                                background: idx == selected-device-index ? #094771 : (Math.mod(idx, 2) == 0 ? #2a2a2a : #252526);
                                border-radius: 4px;

                                TouchArea {
                                    clicked => { select-device(idx); }
                                }

                                HorizontalLayout {
                                    padding: 6px;
                                    spacing: 6px;

                                    VerticalLayout {
                                        alignment: start;

                                        Text {
                                            text: device.name;
                                            font-size: 13px;
                                            font-weight: 600;
                                            color: #e0e0e0;
                                        }

                                        Text {
                                            text: device.id + " | " + device.connection-type;
                                            font-size: 11px;
                                            color: #888;
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: end;

                                        // 状态圆点
                                        Rectangle {
                                            width: 10px;
                                            height: 10px;
                                            border-radius: 5px;
                                            background: device.online ? #4caf50 : (device.connected ? #ff9800 : #f44336);
                                        }

                                        Text {
                                            text: device.online ? "在线" : (device.connected ? "已连接" : "离线");
                                            font-size: 11px;
                                            color: device.online ? #4caf50 : (device.connected ? #ff9800 : #f44336);
                                        }
                                    }
                                }
                            }

                            // 添加设备按钮
                            Button {
                                text: "+ 添加设备";
                                clicked => { add-device("new-device"); }
                            }
                        }
                    }
                }
            }

            // === 中间: 数据区 ===
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 6px;

                TabWidget {
                    vertical-stretch: 1;

                    Tab {
                        title: "📈 实时数据";

                        ScrollView {
                            VerticalLayout {
                                spacing: 2px;

                                // 表头
                                Rectangle {
                                    height: 28px;
                                    background: #333;
                                    border-radius: 2px;

                                    HorizontalLayout {
                                        padding: 4px;
                                        spacing: 12px;

                                        Text { text: "时间戳"; width: 80px; font-weight: 600; color: #aaa; font-size: 11px; }
                                        Text { text: "通道 0"; width: 80px; font-weight: 600; color: #4fc3f7; font-size: 11px; }
                                        Text { text: "通道 1"; width: 80px; font-weight: 600; color: #81c784; font-size: 11px; }
                                        Text { text: "通道 2"; width: 80px; font-weight: 600; color: #ffb74d; font-size: 11px; }
                                        Text { text: "通道 3"; width: 80px; font-weight: 600; color: #e57373; font-size: 11px; }
                                    }
                                }

                                for item[idx] in telemetry-data : Rectangle {
                                    height: 26px;
                                    background: Math.mod(idx, 2) == 0 ? #2a2a2a : #252526;

                                    HorizontalLayout {
                                        padding: 2px;
                                        spacing: 12px;

                                        Text { text: item.timestamp; width: 80px; font-size: 11px; color: #aaa; font-family: "monospace"; }
                                        Text { text: round(item.ch0 * 1000) / 1000; width: 80px; font-size: 11px; color: #4fc3f7; font-family: "monospace"; }
                                        Text { text: round(item.ch1 * 1000) / 1000; width: 80px; font-size: 11px; color: #81c784; font-family: "monospace"; }
                                        Text { text: round(item.ch2 * 1000) / 1000; width: 80px; font-size: 11px; color: #ffb74d; font-family: "monospace"; }
                                        Text { text: round(item.ch3 * 1000) / 1000; width: 80px; font-size: 11px; color: #e57373; font-family: "monospace"; }
                                    }
                                }
                            }
                        }
                    }

                    Tab {
                        title: "📊 统计";

                        ScrollView {
                            VerticalLayout {
                                spacing: 4px;

                                for stat[idx] in channel-stats : Rectangle {
                                    height: 48px;
                                    background: Math.mod(idx, 2) == 0 ? #2a2a2a : #252526;
                                    border-radius: 4px;

                                    HorizontalLayout {
                                        padding: 8px;
                                        spacing: 20px;

                                        Text { text: "CH " + stat.channel-id; width: 50px; font-weight: 700; color: #fff; }
                                        VerticalLayout {
                                            Text { text: "最小"; font-size: 10px; color: #888; }
                                            Text { text: round(stat.min * 1000) / 1000; color: #81c784; font-size: 13px; font-family: "monospace"; }
                                        }
                                        VerticalLayout {
                                            Text { text: "最大"; font-size: 10px; color: #888; }
                                            Text { text: round(stat.max * 1000) / 1000; color: #e57373; font-size: 13px; font-family: "monospace"; }
                                        }
                                        VerticalLayout {
                                            Text { text: "平均"; font-size: 10px; color: #888; }
                                            Text { text: round(stat.avg * 1000) / 1000; color: #64b5f6; font-size: 13px; font-family: "monospace"; }
                                        }
                                        VerticalLayout {
                                            Text { text: "RMS"; font-size: 10px; color: #888; }
                                            Text { text: round(stat.rms * 1000) / 1000; color: #ffb74d; font-size: 13px; font-family: "monospace"; }
                                        }
                                        VerticalLayout {
                                            Text { text: "样本"; font-size: 10px; color: #888; }
                                            Text { text: stat.sample-count; color: #aaa; font-size: 13px; font-family: "monospace"; }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Tab {
                        title: "🔔 告警";

                        VerticalLayout {
                            padding: 4px;
                            spacing: 4px;

                            HorizontalLayout {
                                alignment: end;
                                Button { text: "清除全部"; clicked => { clear-alarms(); } }
                            }

                            ScrollView {
                                vertical-stretch: 1;

                                VerticalLayout {
                                    spacing: 4px;

                                    for alarm[idx] in alarm-records : Rectangle {
                                        height: 52px;
                                        background: alarm.acknowledged ? #252526 : #3e2723;
                                        border-radius: 4px;

                                        VerticalLayout {
                                            padding: 4px;
                                            spacing: 2px;

                                            HorizontalLayout {
                                                spacing: 8px;

                                                Rectangle {
                                                    width: 6px;
                                                    border-radius: 3px;
                                                    background: alarm.level == "CRITICAL" ? #f44336 : (alarm.level == "WARNING" ? #ff9800 : #2196f3);
                                                }

                                                Text {
                                                    text: alarm.level;
                                                    font-weight: 700;
                                                    color: alarm.level == "CRITICAL" ? #f44336 : (alarm.level == "WARNING" ? #ff9800 : #2196f3);
                                                }
                                                Text { text: alarm.device-id + " CH" + alarm.channel-id; color: #ccc; }
                                                Text { text: "值: " + round(alarm.value * 100) / 100; color: #aaa; }
                                            }

                                            Text { text: alarm.message; font-size: 11px; color: #999; overflow: TextOverflow.elide; }

                                            HorizontalLayout {
                                                spacing: 8px;
                                                Text { text: alarm.timestamp; font-size: 10px; color: #666; }

                                                if !alarm.acknowledged : Button {
                                                    text: "确认";
                                                    height: 20px;
                                                    clicked => { acknowledge-alarm(idx); }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Tab {
                        title: "📋 日志";

                        ScrollView {
                            VerticalLayout {
                                spacing: 1px;
                                for msg[idx] in log-messages : Text {
                                    text: msg;
                                    font-size: 11px;
                                    color: #aaa;
                                    font-family: "monospace";
                                }
                            }
                        }
                    }
                }
            }

            // === 右侧: 配置面板 ===
            Rectangle {
                max-width: 320px;
                background: #252526;
                border-radius: 4px;

                TabWidget {
                    Tab {
                        title: "MQTT";

                        VerticalLayout {
                            padding: 8px;
                            spacing: 6px;

                            // MQTT 连接状态
                            Rectangle {
                                height: 24px;
                                background: mqtt-connected ? #1b5e20 : #333;
                                border-radius: 12px;

                                Text {
                                    text: mqtt-connected ? "● MQTT 已连接" : "○ MQTT 未连接";
                                    color: mqtt-connected ? #4caf50 : #888;
                                    horizontal-alignment: center;
                                }
                            }

                            Text { text: "Broker 地址:"; color: #aaa; }
                            LineEdit { text <=> mqtt-host; }

                            Text { text: "端口:"; color: #aaa; }
                            SpinBox { value <=> mqtt-port; minimum: 1; maximum: 65535; }

                            Text { text: "用户名:"; color: #aaa; }
                            LineEdit { text <=> mqtt-username; }

                            Text { text: "密码:"; color: #aaa; }
                            LineEdit { text <=> mqtt-password;  }

                            Text { text: "客户端 ID:"; color: #aaa; }
                            LineEdit { text <=> mqtt-client-id; }

                            CheckBox { text: "启用 TLS"; checked <=> mqtt-tls; }

                            HorizontalLayout {
                                spacing: 8px;
                                Button { text: "连接"; clicked => { connect-mqtt(); } }
                                Button { text: "断开"; clicked => { disconnect-mqtt(); } }
                            }
                        }
                    }

                    Tab {
                        title: "告警";

                        VerticalLayout {
                            padding: 8px;
                            spacing: 6px;

                            CheckBox { text: "启用告警监控"; checked <=> alarm-enabled; }

                            Text { text: "下限阈值:"; color: #aaa; }
                            SpinBox { value <=> alarm-lower-int; minimum: -100000; maximum: 100000; }

                            Text { text: "上限阈值:"; color: #aaa; }
                            SpinBox { value <=> alarm-upper-int; minimum: -100000; maximum: 100000; }

                            Button { text: "应用告警配置"; clicked => { save-config(); } }
                        }
                    }

                    Tab {
                        title: "通用";

                        VerticalLayout {
                            padding: 8px;
                            spacing: 6px;

                            Text { text: "配置管理"; font-weight: 700; color: #e0e0e0; }

                            Button { text: "💾 保存配置"; clicked => { save-config(); } }
                            Button { text: "📂 加载配置"; clicked => { load-config(); } }
                            Button { text: "🔄 重置默认"; clicked => { reset-config(); } }

                            Rectangle { height: 16px; }

                            Text { text: "数据导出"; font-weight: 700; color: #e0e0e0; }

                            Button { text: "📊 导出 CSV"; clicked => { export-csv(); } }
                            Button { text: "📄 导出 JSON"; clicked => { export-json(); } }
                        }
                    }
                }
            }
        }

        // ============ 状态栏 ============
        Rectangle {
            height: 28px;
            background: #007acc;
            border-radius: 2px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 16px;

                Text { text: status-message; color: #fff; vertical-alignment: center; }
                Rectangle { horizontal-stretch: 1; }
                Text { text: "设备: " + connected-count + " 已连接 | " + online-count + " 在线"; color: #ddd; vertical-alignment: center; }
                Text { text: recording ? "⏺ 记录中" : ""; color: #ff5252; vertical-alignment: center; }
                Text { text: mqtt-connected ? "☁ MQTT" : ""; color: #ddd; vertical-alignment: center; }
            }
        }
    }
}
