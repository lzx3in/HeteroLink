# Serial Logs & Debug
# ==============================================================================
*.log
core.*
crash_*.dmp
flash_logs/

# ==============================================================================
# IDE & Editor
# ==============================================================================
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==============================================================================
# Python (ESP-IDF tools)
# ==============================================================================
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# ==============================================================================
# Temporary Files
# ==============================================================================
tmp/
temp/
*.tmp
