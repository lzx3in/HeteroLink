# HeteroLink ESP32-C6 Subboard 固件默认配置

# WiFi 连接
CONFIG_EXAMPLE_WIFI_SSID="lizixin"
CONFIG_EXAMPLE_WIFI_PASSWORD="***"

# 分区表
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# Flash 大小 (8MB)
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="8MB"

# MQTT5 协议
CONFIG_MQTT_PROTOCOL_5=y

# 功能：仅 WiFi + MQTT + ADC/GPIO
# CONFIG_HETERO_ENABLE_UART_PROTOCOL is not set
# CONFIG_HETERO_ENABLE_SPI_DMA is not set
CONFIG_HETERO_ENABLE_ADC_GPIO_PROBE=y

# 调试
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
